<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Unit Optimizer / ユニット最適化</title>
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <main class="app">
    <header class="panel">
      <h1>Unit Optimizer / ユニット最適化</h1>
      <p class="hint-text">盤を選び、所持ユニットを入力して「最適化」を押してください。</p>
    </header>

    <section class="panel">
      <h2>盤の選択 / Boards</h2>
      <div id="boardSelect" class="board-select"></div>
    </section>

    <section class="panel">
      <div class="row-between">
        <h2>盤面 / Boards</h2>
        <div class="toolbar">
          <label for="paintGrade" class="sr-label">品質</label>
          <select id="paintGrade" class="paint-grade"></select>
          <button id="paintToggle" class="active">paint</button>
          <button id="eraseToggle">erase</button>
          <button id="manualToggle">manual</button>
          <button id="resetBoard">reset</button>
        </div>
      </div>
      <div id="boards" class="boards"></div>
    </section>

    <section class="panel">
      <h2>所持ユニット / Units</h2>
      <p class="hint-text">各ユニットの所持数を入力</p>
      <div id="inventory" class="inventory"></div>
    </section>

    <section class="panel actions-panel">
      <button id="solveBtn" class="primary">最適化 / Solve</button>
      <div id="status" class="status">準備完了</div>
    </section>

    <section class="panel" id="unusedPanel" hidden>
      <h2>未使用ユニット / Unused</h2>
      <div id="unusedList" class="unused-list"></div>
    </section>
  </main>

  <script src="script.js"></script>
</body>
</html>
